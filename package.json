  "repository": {
    "type": "git",
    "url": "https://github.com/icex-labs/icex-flow.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "typescript": "^6.0.2"
  }
}
