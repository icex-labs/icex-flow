{
  "name": "icex-flow",
  "version": "0.1.0",
  "description": "Deterministic agent workflow orchestration — eliminate randomness in AI agent pipelines",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "icex-flow": "bin/icex-flow.mjs"
  },
  "scripts": {
    "build": "tsc",
